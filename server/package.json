{
  "name": "baobab-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend API pour BAOBAB",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "mongo:docker": "docker run --name baobab-mongo -p 27017:27017 -v baobab-mongo-data:/data/db -d mongo:7",
    "mongo:start": "docker start baobab-mongo",
    "lint": "find src tests scripts -name '*.js' -print0 | xargs -0 -n1 node --check",
    "test": "NODE_ENV=test node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage",
    "test:watch": "NODE_ENV=test node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "test:email": "node scripts/test-email.js",
    "test:2fa": "node scripts/test-2fa.js",
    "seed:demo": "node src/scripts/seedDemoCommerceBlog.js",
    "check:security": "node scripts/check-security.js"
  },
  "dependencies": {
    "@stripe/stripe-js": "^8.6.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.11",
    "redis": "^4.6.0",
    "sharp": "^0.34.5",
    "stripe": "^20.1.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@sentry/node": "^8.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "mongodb-memory-server": "^10.0.0"
  }
}
